{
  "name": "changelog-impact",
  "version": "0.2.0",
  "description": "Changelog-to-Impact Copilot: track Stripe/OpenAI changes, scan repo, generate local impact reports.",
  "type": "module",
  "bin": {
    "changelog-impact": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
