  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "eslint": "^9.9.0",
    "typescript": "^5.6.3",
    "tsx": "^4.19.1",
    "vitest": "^2.1.8"
  }
}
